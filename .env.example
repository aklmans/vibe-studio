DATABASE_URL=postgres://user:password@localhost:5432/vibe_coding_live

# Session Config Agent (optional). When SESSION_AGENT_API_KEY is set, the Agent
# tab can call a real model via the server route /api/session-config/agent.
# The key stays server-side only. If unset, the Agent falls back to local
# handoff (Copy handoff) and no provider request is made. Never commit a real key.
SESSION_AGENT_PROVIDER=deepseek
SESSION_AGENT_BASE_URL=https://api.deepseek.com
SESSION_AGENT_API_KEY=
SESSION_AGENT_MODEL=deepseek-chat
SESSION_AGENT_USER_AGENT=Vibe-Studio/SessionConfigAgent

# Public-showcase abuse guardrails (optional). Applied ONLY when VIBE_SHOWCASE=1,
# so anonymous visitors can try the agent without the deploy's key being an open
# cost/DoS surface. A local/private Studio ignores these and runs uncapped.
#   SESSION_AGENT_RATE_LIMIT  agent runs per IP per hour (default 10; 0 = off)
#   SESSION_AGENT_MAX_TOKENS  cap on provider output tokens (default 4096)
SESSION_AGENT_RATE_LIMIT=
SESSION_AGENT_MAX_TOKENS=

# Deployment mode (optional). Unset (default) = "app" mode: "/" redirects to the
# studio, so a self-hosted / forked instance never lands on the owner-branded
# marketing page. Set VIBE_SHOWCASE=1 only on the public showcase deploy to
# serve the marketing landing at "/". /demo, /studio and /obs/* are unaffected.
VIBE_SHOWCASE=
