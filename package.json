{
  "name": "vibe-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "dev": "next dev",
    "dev:showcase": "VIBE_SHOWCASE=1 next dev",
    "build": "next build",
    "start": "next start",
    "live:prepare": "tsx scripts/prepare-live.ts prepare",
    "live:status": "tsx scripts/prepare-live.ts status",
    "live:stop": "tsx scripts/prepare-live.ts stop",
    "live:restart": "tsx scripts/prepare-live.ts restart",
    "landing:images": "tsx scripts/optimize-landing-images.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lobehub/icons": "^5.10.1",
    "@radix-ui/react-alert-dialog": "^1.1.18",
    "@radix-ui/react-slot": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "html-to-image": "^1.11.13",
    "next": "^16.2.10",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "simple-icons": "^16.24.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.9.4",
    "tsx": "^4.22.5",
    "typescript": "~6.0.3"
  }
}
